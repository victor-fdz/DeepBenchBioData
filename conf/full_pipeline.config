params {
    outdir = 'results'
    publish_mode = 'copy'

    /*
     * Input files.
     * These can be passed in the command line instead of edited here.
     */
    input = null
    human_fasta = null
    mouse_fasta = null
    gene_list = null

    /*
     * Normalization benchmark.
     */
    normalization_tissue = 'General'
    normalization_selection_metric = 'pearson_increment'
    normalization_methods = ''

    /*
     * Profiling benchmark.
     */
    profiling_promoter = ''

    /*
     * Labeling.
     */
    pairing = 'cross_species'
    labeling = 'rank_labeling_random'
    n_pos = 10000
    n_neg = 10000

    /*
     * Encoding/splitting.
     */
    split_mode = 'anti_leakage'
    val_frac = 0.1
    test_frac = 0.05
    random_seqs = false

    /*
     * Shared random seed.
     */
    seed = 42

    /*
     * Model training/evaluation.
     */
    batch_size = 32
    epochs = 15
    learning_rate = 1e-5
    margin = 1.0
    dropout = 0
    weight_decay = 0.001

    small_kernel_size = 6
    medium_kernel_size = 10
    large_kernel_size = 18
    attention_heads = 4
    embedding_dim = 16

    optimize = false
    optuna_trials = 20
    optuna_jobs = 1
    optuna_epochs = 8
}

profiles {
    local {
        process.executor = 'local'
    }

    /*
     * Use this only if conda is available in the shell running Nextflow locally.
     * On the cluster, prefer the slurm profile below.
     */
    conda {
        conda.enabled = true
        process.conda = 'envs/environment.yml'
    }

    /*
     * Cluster profile.
     *
     * Important:
     * - The main Nextflow command must be submitted through the SLURM launcher
     *   script using --qos=pipelines.
     * - This profile controls the worker jobs launched by Nextflow.
     * - Each worker job activates env_tfm before running Python.
     */
    slurm {
        executor {
            pollInterval = '60 sec'
        }

        process {
            executor = 'slurm'
            queue = 'genoa64'
            cache = 'lenient'

            cpus = 1
            memory = '8 GB'
            time = '2h'

            beforeScript = '''
            source "$HOME/miniforge3/etc/profile.d/conda.sh"
            conda activate env_tfm
            '''

            withName: 'NORMALIZATION_BENCHMARK' {
                cpus = 2
                memory = '8 GB'
                time = '2h'
            }

            withName: 'PROFILING_BENCHMARK' {
                cpus = 2
                memory = '8 GB'
                time = '2h'
            }

            withName: 'LABEL_GENE_PAIRS' {
                cpus = 2
                memory = '8 GB'
                time = '2h'
            }

            withName: 'ENCODE_AND_SPLIT_PAIRS' {
                cpus = 2
                memory = '8 GB'
                time = '2h'
            }

            withName: 'TRAIN_AND_EVALUATE_MODEL' {
                cpus = 8
                memory = '32 GB'
                time = '12h'
            }
        }
    }
}

env.NXF_DEBUG = '0'