params {
    outdir = 'results'
    publish_mode = 'copy'

    input = null
    human_fasta = null
    mouse_fasta = null
    gene_list = null

    normalization_tissue = 'General'
    normalization_selection_metric = 'pearson_increment'

    profiling_promoter = ''

    pairing = 'cross_species'
    labeling = 'rank_labeling_random'
    n_pos = 10000
    n_neg = 10000

    split_mode = 'anti_leakage'
    val_frac = 0.1
    test_frac = 0.05
    random_seqs = false

    seed = 42

    batch_size = 32
    epochs = 15
    learning_rate = 1e-5
    margin = 1.0
    dropout = 0
    weight_decay = 0.001

    small_kernel_size = 6
    medium_kernel_size = 10
    large_kernel_size = 18
    attention_heads = 4
    embedding_dim = 16

    optimize = false
    optuna_trials = 20
    optuna_jobs = 1
    optuna_epochs = 8
}

profiles {
    local {
        process.executor = 'local'
    }

    conda {
        conda.enabled = true
        process.conda = 'envs/environment.yml'
    }
}

process {
    withName: 'NORMALIZATION_BENCHMARK' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'PROFILING_BENCHMARK' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'LABEL_GENE_PAIRS_FROM_BENCHMARKS' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'ENCODE_AND_SPLIT_PAIRS_FROM_BENCHMARKS' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'TRAIN_AND_EVALUATE_MODEL_FROM_BENCHMARKS' {
        cpus = 2
        memory = '8 GB'
        time = '8h'
    }
}
