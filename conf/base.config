workDir = 'work'

process {
    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = 'terminate'

    withName: LABEL_GENE_PAIRS {
        cpus = 1
        memory = '4 GB'
        time = '2h'
    }

    withName: ENCODE_AND_SPLIT_PAIRS {
        cpus = 2
        memory = '2 GB'
        time = '0.5h'
    }

    withName: TRAIN_AND_EVALUATE_MODEL {
        cpus = 4
        memory = '2 GB'
        time = '1h'
    }

    withName: NORMALIZATION_BENCHMARK {
        cpus = 1
        memory = '1 GB'
        time = '0.5h'
    }

    withName: PROFILING_BENCHMARK {
        cpus = 2
        memory = '1 GB'
        time = '0.5h'
    }
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/nextflow_reports/trace.txt"
}

timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/nextflow_reports/timeline.html"
}

report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/nextflow_reports/report.html"
}

dag {
    enabled = true
    overwrite = true
    file = "${params.outdir}/nextflow_reports/pipeline_dag.html"
}
