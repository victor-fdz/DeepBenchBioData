params {
    outdir = 'results'
    publish_mode = 'copy'

    normalization = 'quantile_norm'
    pairing = 'cross_species'
    profiling = 'cosine_sim'
    labeling = 'rank_labeling_random'

    n_pos = 10000
    n_neg = 10000
    seed = 42
}

profiles {
    local {
        process.executor = 'local'
    }

    conda {
        conda.enabled = true
        process.conda = 'envs/environment.yml'
    }
}

process {
    withName: 'LABEL_GENE_PAIRS' {
        cpus = 1
        memory = '1 GB'
        time = '0.5h'
    }
}
